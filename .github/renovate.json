{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Amsterdam",
  "schedule": [
    "before 9am every day"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "separateMajorMinor": true,
  "vulnerabilityAlerts": {
    "labels": [
      "dependencies",
      "security"
    ],
    "prPriority": 5
  },
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "web/package.json"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "frontend",
      "labels": [
        "dependencies",
        "frontend"
      ]
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "go.mod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "backend",
      "labels": [
        "dependencies",
        "backend"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github-actions",
      "labels": [
        "dependencies",
        "github-actions"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "dependencies",
        "major-update"
      ]
    }
  ]
}
