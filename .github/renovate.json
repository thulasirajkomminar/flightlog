{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs"
  ],
  "timezone": "Europe/Amsterdam",
  "schedule": [
    "before 9am every day"
  ],
  "labels": [
    "dependencies"
  ],
  "automerge": false,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 3,
  "rebaseWhen": "behind-base-branch",
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "ignorePaths": [
    "**/vendor/**"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "dependencies",
      "security"
    ]
  },
  "customManagers": [
    {
      "description": "Go version in CI workflows",
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/.*\\.ya?ml$"
      ],
      "matchStrings": [
        "go-version[:\\s]+['\"]?(?<currentValue>[\\d\\.]+)['\"]?"
      ],
      "depNameTemplate": "golang",
      "datasourceTemplate": "golang-version"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "web/package.json"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "frontend",
      "labels": [
        "dependencies",
        "frontend"
      ]
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "go.mod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "backend",
      "labels": [
        "dependencies",
        "backend"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github-actions",
      "labels": [
        "dependencies",
        "github-actions"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "dependencies",
        "major-update"
      ]
    }
  ]
}
