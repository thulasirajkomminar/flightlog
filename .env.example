# Development environment
ENVIRONMENT=development

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Server configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# AeroDataBox API configuration
AERODATABOX_API_KEY=your_api_key_here
AERODATABOX_BASE_URL=https://aerodatabox.p.rapidapi.com
AERODATABOX_TIMEOUT=30s

# Rate limiting configuration
RATE_LIMIT_IP_REQUESTS_PER_MINUTE=100
RATE_LIMIT_USER_REQUESTS_PER_MINUTE=200

# Authentication configuration
AUTH_JWT_SECRET=your_jwt_secret_here
AUTH_TOKEN_EXPIRY=24h
